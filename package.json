{
	"name": "forty-fives",
	"private": true,
	"version": "0.2.57",
	"type": "module",
	"license": "Apache-2.0",
	"engines": {
		"node": "^20.19 || ^22.12 || >=24"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"build:gh-pages": "BASE_PATH=/forty-fives vite build",
		"deploy:gh-pages": "npm run build:gh-pages && gh-pages -d build --dotfiles"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^22.19.20",
		"gh-pages": "^6.3.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	}
}
